# ---- Go ----
# Vendored modules are generated on demand (`go mod vendor`) by CI and the
# flatpak/release scripts — 69 MB of churn, never committed.
/vendor/
# Local ad-hoc build output (the real builds go to build/bin, ignored below)
/novelide
/novelide.exe
/novelide-*
# Test / coverage artifacts
*.test
*.out
*.cover
coverage.*
# Go workspace files (local only)
go.work
go.work.sum

# ---- Wails / frontend build output ----
# Compiled app binaries (wails build -> build/bin/{novelide,novelide.exe,novelide.app})
build/bin/
# Node dependencies (any level)
node_modules/
# Auto-generated Wails JS bindings ("DO NOT EDIT"; regenerated by wails build)
frontend/wailsjs/
# Built frontend (embedded via go:embed at build time). Ignored, but keep a
# placeholder so `go build`/go:embed works on a fresh clone before the
# frontend is built. Ignore the CONTENTS, not the directory, so the
# negation can re-include .gitkeep.
/frontend/dist/*
!/frontend/dist/.gitkeep
# Vite / frontend local overrides
*.local

# ---- Flatpak build state & artifacts ----
# flatpak-builder writes .flatpak-builder wherever it runs (repo root and
# build/flatpak/), plus the intermediate build/repo dirs. All generated.
.flatpak-builder/
build/flatpak/.flatpak-build/
build/flatpak/.flatpak-repo/
# Generated bundles and vendored source tarballs
build/flatpak/*.flatpak
build/flatpak/*.tar.xz
build/flatpak/*.tar.xz.sha256
# Release staging dir (created by the release workflow / local runs)
/dist/
#
# NOTE — deliberately committed (source the flatpak/release builds need):
#   build/flatpak/dicts/           bundled hunspell dictionaries
#   build/flatpak/icon-512.png     app icon (referenced by the manifest)
#   build/flatpak/*.yml *.sh *.desktop *.metainfo.xml  packaging inputs
#   build/appicon.png build/darwin build/windows        wails template assets

# ---- Editors / IDEs ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS cruft ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Claude Code ----
.claude/

# ---- Logs ----
*.log
